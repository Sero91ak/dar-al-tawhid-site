{"id":108,"name":"الكوثر","transliteration":"Al-Kawthar","type":"meccan","total_verses":3,"verses":[{"id":1,"ar":"إِنَّآ أَعۡطَيۡنَٰكَ ٱلۡكَوۡثَرَ","tr":"Inna aAAtaynaka alkawthara","de":"Wir haben dir ja al-Kautar gegeben"},{"id":2,"ar":"فَصَلِّ لِرَبِّكَ وَٱنۡحَرۡ","tr":"Fasalli lirabbika wainhar","de":"So bete zu deinem Herrn und opfere"},{"id":3,"ar":"إِنَّ شَانِئَكَ هُوَ ٱلۡأَبۡتَرُ","tr":"Inna shaniaka huwa alabtaru","de":"Gewiß, derjenige, der dich haßt, - er ist vom Guten abgetrennt"}]}