{"id":109,"name":"الكافرون","transliteration":"Al-Kafirun","type":"meccan","total_verses":6,"verses":[{"id":1,"ar":"قُلۡ يَـٰٓأَيُّهَا ٱلۡكَٰفِرُونَ","tr":"Qul ya ayyuha alkafiroona","tr_readable":"Qul yaa-ai yuhal kaafiroon","tr_academic":"qul yāayyuhā l-kāfirūna","de":"Sag: O ihr Ungläubigen"},{"id":2,"ar":"لَآ أَعۡبُدُ مَا تَعۡبُدُونَ","tr":"La aAAbudu ma taAAbudoona","tr_readable":"Laa a'budu ma t'abudoon","tr_academic":"lā aʿbudu mā taʿbudūna","de":"ich diene nicht dem, dem ihr dient"},{"id":3,"ar":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","tr":"Wala antum AAabidoona ma aAAbudu","tr_readable":"Wa laa antum 'aabidoona maa a'bud","tr_academic":"walā antum ʿābidūna mā aʿbudu","de":"und ihr dient nicht Dem, Dem ich diene"},{"id":4,"ar":"وَلَآ أَنَا۠ عَابِدٞ مَّا عَبَدتُّمۡ","tr":"Wala ana AAabidun ma AAabadtum","tr_readable":"Wa laa ana 'abidum maa 'abattum","tr_academic":"walā anā ʿābidun mā ʿabadttum","de":"Und ich werde (auch) nicht dem dienen, dem ihr gedient habt"},{"id":5,"ar":"وَلَآ أَنتُمۡ عَٰبِدُونَ مَآ أَعۡبُدُ","tr":"Wala antum AAabidoona ma aAAbudu","tr_readable":"Wa laa antum 'aabidoona ma a'bud","tr_academic":"walā antum ʿābidūna mā aʿbudu","de":"Und ihr werdet nicht Dem dienen, Dem ich diene"},{"id":6,"ar":"لَكُمۡ دِينُكُمۡ وَلِيَ دِينِ","tr":"Lakum deenukum waliya deeni","tr_readable":"Lakum deenukum wa liya deen.","tr_academic":"lakum dīnukum waliya dīni","de":"Euch eure Religion und mir meine Religion"}]}