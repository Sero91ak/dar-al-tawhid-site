{"id":104,"name":"الهمزة","transliteration":"Al-Humazah","type":"meccan","total_verses":9,"verses":[{"id":1,"ar":"وَيۡلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ","tr":"Waylun likulli humazatin lumazatin","de":"Wehe jedem Stichler und Nörgler"},{"id":2,"ar":"ٱلَّذِي جَمَعَ مَالٗا وَعَدَّدَهُۥ","tr":"Allathee jamaAAa malan waAAaddadahu","de":"der Besitz zusammenträgt und ihn zählt und immer wieder zählt"},{"id":3,"ar":"يَحۡسَبُ أَنَّ مَالَهُۥٓ أَخۡلَدَهُۥ","tr":"Yahsabu anna malahu akhladahu","de":"wobei er meint, daß sein Besitz ihn ewig leben ließe"},{"id":4,"ar":"كَلَّاۖ لَيُنۢبَذَنَّ فِي ٱلۡحُطَمَةِ","tr":"Kalla layunbathanna fee alhutamati","de":"Keineswegs! Er wird ganz gewiß in al-Hutama geworfen werden"},{"id":5,"ar":"وَمَآ أَدۡرَىٰكَ مَا ٱلۡحُطَمَةُ","tr":"Wama adraka ma alhutamatu","de":"Was läßt dich wissen, was al-Hutama ist"},{"id":6,"ar":"نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ","tr":"Naru Allahi almooqadatu","de":"(Sie ist) Allahs entfachtes Feuer"},{"id":7,"ar":"ٱلَّتِي تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ","tr":"Allatee tattaliAAu AAala alafidati","de":"das Einblick in die Herzen gewinnt"},{"id":8,"ar":"إِنَّهَا عَلَيۡهِم مُّؤۡصَدَةٞ","tr":"lnnaha AAalayhim musadatun","de":"Gewiß, es wird sie einschließen"},{"id":9,"ar":"فِي عَمَدٖ مُّمَدَّدَةِۭ","tr":"Fee AAamadin mumaddadatin","de":"in langgestreckten Säulen"}]}