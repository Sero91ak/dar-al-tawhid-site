{"id":114,"name":"الناس","transliteration":"An-Nas","type":"meccan","total_verses":6,"verses":[{"id":1,"ar":"قُلۡ أَعُوذُ بِرَبِّ ٱلنَّاسِ","tr":"Qul aAAoothu birabbi alnnasi","de":"Sag: Ich nehme Zuflucht beim Herrn der Menschen"},{"id":2,"ar":"مَلِكِ ٱلنَّاسِ","tr":"Maliki alnnasi","de":"dem König der Menschen"},{"id":3,"ar":"إِلَٰهِ ٱلنَّاسِ","tr":"Ilahi alnnasi","de":"dem Gott der Menschen"},{"id":4,"ar":"مِن شَرِّ ٱلۡوَسۡوَاسِ ٱلۡخَنَّاسِ","tr":"Min sharri alwaswasi alkhannasi","de":"vor dem Übel des Einflüsterers, des Davonschleichers"},{"id":5,"ar":"ٱلَّذِي يُوَسۡوِسُ فِي صُدُورِ ٱلنَّاسِ","tr":"Allathee yuwaswisu fee sudoori alnnasi","de":"der in die Brüste der Menschen einflüstert"},{"id":6,"ar":"مِنَ ٱلۡجِنَّةِ وَٱلنَّاسِ","tr":"Mina aljinnati wa alnnasm","de":"von den Ginn und den Menschen"}]}