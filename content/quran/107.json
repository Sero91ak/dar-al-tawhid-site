{"id":107,"name":"الماعون","transliteration":"Al-Ma'un","type":"meccan","total_verses":7,"verses":[{"id":1,"ar":"أَرَءَيۡتَ ٱلَّذِي يُكَذِّبُ بِٱلدِّينِ","tr":"Araayta allathee yukaththibu bialddeeni","de":"Siehst du (nicht) denjenigen, der das Gericht für Lüge erklärt"},{"id":2,"ar":"فَذَٰلِكَ ٱلَّذِي يَدُعُّ ٱلۡيَتِيمَ","tr":"Fathalika allathee yaduAAAAu alyateema","de":"Das ist derjenige, der die Waise zurückstößt"},{"id":3,"ar":"وَلَا يَحُضُّ عَلَىٰ طَعَامِ ٱلۡمِسۡكِينِ","tr":"Wala yahuddu AAala taAAami almiskeeni","de":"und nicht zur Speisung des Armen anhält"},{"id":4,"ar":"فَوَيۡلٞ لِّلۡمُصَلِّينَ","tr":"Fawaylun lilmusalleena","de":"Wehe nun den Betenden"},{"id":5,"ar":"ٱلَّذِينَ هُمۡ عَن صَلَاتِهِمۡ سَاهُونَ","tr":"Allatheena hum AAan salatihim sahoona","de":"denjenigen, die auf ihre Gebete nicht achten"},{"id":6,"ar":"ٱلَّذِينَ هُمۡ يُرَآءُونَ","tr":"Allatheena hum yuraoona","de":"denjenigen, die dabei (nur) gesehen werden wollen"},{"id":7,"ar":"وَيَمۡنَعُونَ ٱلۡمَاعُونَ","tr":"WayamnaAAoona almaAAoona","de":"und die Hilfeleistung verweigern"}]}