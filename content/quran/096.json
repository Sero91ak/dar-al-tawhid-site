{"id":96,"name":"العلق","transliteration":"Al-'Alaq","type":"meccan","total_verses":19,"verses":[{"id":1,"ar":"ٱقۡرَأۡ بِٱسۡمِ رَبِّكَ ٱلَّذِي خَلَقَ","tr":"Iqra biismi rabbika allathee khalaqa","tr_readable":"Iqra bismi rab bikal lazee khalaq","tr_academic":"iq'ra bi-is'mi rabbika alladhī khalaqa","de":"Lies im Namen deines Herrn, Der erschaffen hat"},{"id":2,"ar":"خَلَقَ ٱلۡإِنسَٰنَ مِنۡ عَلَقٍ","tr":"Khalaqa alinsana min AAalaqin","tr_readable":"Khalaqal insaana min 'alaq","tr_academic":"khalaqa l-insāna min ʿalaqin","de":"den Menschen erschaffen hat aus einem Anhängsel"},{"id":3,"ar":"ٱقۡرَأۡ وَرَبُّكَ ٱلۡأَكۡرَمُ","tr":"Iqra warabbuka alakramu","tr_readable":"Iqra wa rab bukal akram","tr_academic":"iq'ra warabbuka l-akramu","de":"Lies, und dein Herr ist der Edelste"},{"id":4,"ar":"ٱلَّذِي عَلَّمَ بِٱلۡقَلَمِ","tr":"Allathee AAallama bialqalami","tr_readable":"Al lazee 'allama bil qalam","tr_academic":"alladhī ʿallama bil-qalami","de":"Der (das Schreiben) mit dem Schreibrohr gelehrt hat"},{"id":5,"ar":"عَلَّمَ ٱلۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ","tr":"AAallama alinsana ma lam yaAAlam","tr_readable":"'Al lamal insaana ma lam y'alam","tr_academic":"ʿallama l-insāna mā lam yaʿlam","de":"den Menschen gelehrt hat, was er nicht wußte"},{"id":6,"ar":"كَلَّآ إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰٓ","tr":"Kalla inna alinsana layatgha","tr_readable":"Kallaa innal insaana layatghaa","tr_academic":"kallā inna l-insāna layaṭghā","de":"Keineswegs! Der Mensch lehnt sich wahrlich auf"},{"id":7,"ar":"أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ","tr":"An raahu istaghna","tr_readable":"Ar-ra aahus taghnaa","tr_academic":"an raāhu is'taghnā","de":"daß er von sich meint, unbedürftig zu sein"},{"id":8,"ar":"إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجۡعَىٰٓ","tr":"Inna ila rabbika alrrujAAa","tr_readable":"Innna ilaa rabbikar ruj'aa","tr_academic":"inna ilā rabbika l-ruj'ʿā","de":"Gewiß, zu deinem Herrn wird die Rückkehr sein"},{"id":9,"ar":"أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ","tr":"Araayta allathee yanha","tr_readable":"Ara-aital lazee yanhaa","tr_academic":"ara-ayta alladhī yanhā","de":"Siehst du denjenigen, der abhält"},{"id":10,"ar":"عَبۡدًا إِذَا صَلَّىٰٓ","tr":"AAabdan itha salla","tr_readable":"'Abdan iza sallaa","tr_academic":"ʿabdan idhā ṣallā","de":"einen Diener, wenn er betet"},{"id":11,"ar":"أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ","tr":"Araayta in kana AAala alhuda","tr_readable":"Ara-aita in kana 'alal hudaa","tr_academic":"ara-ayta in kāna ʿalā l-hudā","de":"Siehst du! Obwohl er nach der Rechtleitung verfährt"},{"id":12,"ar":"أَوۡ أَمَرَ بِٱلتَّقۡوَىٰٓ","tr":"Aw amara bialttaqwa","tr_readable":"Au amara bit taqwaa","tr_academic":"aw amara bil-taqwā","de":"oder die Gottesfurcht gebietet"},{"id":13,"ar":"أَرَءَيۡتَ إِن كَذَّبَ وَتَوَلَّىٰٓ","tr":"Araayta in kaththaba watawalla","tr_readable":"Ara-aita in kaz zaba wa ta walla","tr_academic":"ara-ayta in kadhaba watawallā","de":"Siehst du! Wie (wäre es) wenn er (die Botschaft) für Lüge erklärt und sich abkehrt"},{"id":14,"ar":"أَلَمۡ يَعۡلَم بِأَنَّ ٱللَّهَ يَرَىٰ","tr":"Alam yaAAlam bianna Allaha yara","tr_readable":"Alam y'alam bi-an nal lahaa yaraa","tr_academic":"alam yaʿlam bi-anna l-laha yarā","de":"Weiß er denn nicht, daß Allah sieht"},{"id":15,"ar":"كَلَّا لَئِن لَّمۡ يَنتَهِ لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ","tr":"Kalla lain lam yantahi lanasfaAAan bialnnasiyati","tr_readable":"Kalla la illam yantahi la nasfa'am bin nasiyah","tr_academic":"kallā la-in lam yantahi lanasfaʿan bil-nāṣiyati","de":"Keineswegs! Wenn er nicht aufhört, werden Wir ihn ganz gewiß an der Stirnlocke packen und ziehen"},{"id":16,"ar":"نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖ","tr":"Nasiyatin kathibatin khatiatin","tr_readable":"Nasiyatin kazi batin khaatiyah","tr_academic":"nāṣiyatin kādhibatin khāṭi-atin","de":"einer Stirnlocke, einer lügnerischen, einer verfehlt handelnden"},{"id":17,"ar":"فَلۡيَدۡعُ نَادِيَهُۥ","tr":"FalyadAAu nadiyahu","tr_readable":"Fal yad'u naadiyah","tr_academic":"falyadʿu nādiyahu","de":"So soll er doch seine Genossen rufen"},{"id":18,"ar":"سَنَدۡعُ ٱلزَّبَانِيَةَ","tr":"SanadAAu alzzabaniyata","tr_readable":"Sanad 'uz zabaaniyah","tr_academic":"sanadʿu l-zabāniyata","de":"Wir werden die (Höllen)wache rufen"},{"id":19,"ar":"كَلَّا لَا تُطِعۡهُ وَٱسۡجُدۡۤ وَٱقۡتَرِب۩","tr":"Kalla la tutiAAhu waosjud waiqtarib","tr_readable":"Kalla; la tuti'hu wasjud waqtarib","tr_academic":"kallā lā tuṭiʿ'hu wa-us'jud wa-iq'tarib","de":"Keineswegs! Gehorche ihm nicht, sondern wirf dich nieder und sei (Allah) nah"}]}