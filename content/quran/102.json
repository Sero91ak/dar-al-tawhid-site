{"id":102,"name":"التكاثر","transliteration":"At-Takathur","type":"meccan","total_verses":8,"verses":[{"id":1,"ar":"أَلۡهَىٰكُمُ ٱلتَّكَاثُرُ","tr":"Alhakumu alttakathuru","de":"Die Vermehrung lenkt euch ab"},{"id":2,"ar":"حَتَّىٰ زُرۡتُمُ ٱلۡمَقَابِرَ","tr":"Hatta zurtumu almaqabira","de":"bis ihr die Friedhöfe besucht"},{"id":3,"ar":"كَلَّا سَوۡفَ تَعۡلَمُونَ","tr":"Kalla sawfa taAAlamoona","de":"Keineswegs! Ihr werdet (es noch) erfahren"},{"id":4,"ar":"ثُمَّ كَلَّا سَوۡفَ تَعۡلَمُونَ","tr":"Thumma kalla sawfa taAAlamoona","de":"Abermals: Keineswegs! Ihr werdet (es noch) erfahren"},{"id":5,"ar":"كَلَّا لَوۡ تَعۡلَمُونَ عِلۡمَ ٱلۡيَقِينِ","tr":"Kalla law taAAlamoona AAilma alyaqeeni","de":"Keineswegs! Wenn ihr es nur mit dem Wissen der Gewißheit wüßtet"},{"id":6,"ar":"لَتَرَوُنَّ ٱلۡجَحِيمَ","tr":"Latarawunna aljaheema","de":"Ihr werdet ganz gewiß den Höllenbrand sehen"},{"id":7,"ar":"ثُمَّ لَتَرَوُنَّهَا عَيۡنَ ٱلۡيَقِينِ","tr":"Thumma latarawunnaha AAayna alyaqeeni","de":"Abermals: Ihr werdet ihn mit dem Auge der Gewißheit sehen"},{"id":8,"ar":"ثُمَّ لَتُسۡـَٔلُنَّ يَوۡمَئِذٍ عَنِ ٱلنَّعِيمِ","tr":"Thumma latusalunna yawmaithin AAani alnnaAAeemi","de":"Hierauf werdet ihr an jenem Tag ganz gewiß nach der Wonne gefragt werden"}]}