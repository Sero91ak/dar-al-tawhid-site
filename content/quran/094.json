{"id":94,"name":"الشرح","transliteration":"Ash-Sharh","type":"meccan","total_verses":8,"verses":[{"id":1,"ar":"أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ","tr":"Alam nashrah laka sadraka","tr_readable":"Alam nashrah laka sadrak","tr_academic":"alam nashraḥ laka ṣadraka","de":"Haben Wir dir nicht deine Brust aufgetan"},{"id":2,"ar":"وَوَضَعۡنَا عَنكَ وِزۡرَكَ","tr":"WawadaAAna AAanka wizraka","tr_readable":"Wa wa d'ana 'anka wizrak","tr_academic":"wawaḍaʿnā ʿanka wiz'raka","de":"und dir deine Last abgenommen"},{"id":3,"ar":"ٱلَّذِيٓ أَنقَضَ ظَهۡرَكَ","tr":"Allathee anqada thahraka","tr_readable":"Allazee anqada zahrak","tr_academic":"alladhī anqaḍa ẓahraka","de":"die deinen Rücken niederdrückte"},{"id":4,"ar":"وَرَفَعۡنَا لَكَ ذِكۡرَكَ","tr":"WarafaAAna laka thikraka","tr_readable":"Wa raf 'ana laka zikrak","tr_academic":"warafaʿnā laka dhik'raka","de":"und dir dein Ansehen erhöht"},{"id":5,"ar":"فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا","tr":"Fainna maAAa alAAusri yusran","tr_readable":"Fa inna ma'al usri yusra","tr_academic":"fa-inna maʿa l-ʿus'ri yus'ran","de":"Also gewiß, mit der Erschwernis ist Erleichterung"},{"id":6,"ar":"إِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرٗا","tr":"Inna maAAa alAAusri yusran","tr_readable":"Inna ma'al 'usri yusra","tr_academic":"inna maʿa l-ʿus'ri yus'ran","de":"gewiß, mit der Erschwernis ist Erleichterung"},{"id":7,"ar":"فَإِذَا فَرَغۡتَ فَٱنصَبۡ","tr":"Faitha faraghta fainsab","tr_readable":"Fa iza faragh ta fansab","tr_academic":"fa-idhā faraghta fa-inṣab","de":"Wenn du nun fertig bist, dann strenge dich an"},{"id":8,"ar":"وَإِلَىٰ رَبِّكَ فَٱرۡغَب","tr":"Waila rabbika fairghab","tr_readable":"Wa ilaa rabbika far ghab","tr_academic":"wa-ilā rabbika fa-ir'ghab","de":"und nach deinem Herrn richte dein Begehren aus"}]}