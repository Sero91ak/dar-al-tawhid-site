{"id":94,"name":"الشرح","transliteration":"Ash-Sharh","type":"meccan","total_verses":8,"verses":[{"id":1,"ar":"أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ","tr":"Alam nashrah laka sadraka","de":"Haben Wir dir nicht deine Brust aufgetan"},{"id":2,"ar":"وَوَضَعۡنَا عَنكَ وِزۡرَكَ","tr":"WawadaAAna AAanka wizraka","de":"und dir deine Last abgenommen"},{"id":3,"ar":"ٱلَّذِيٓ أَنقَضَ ظَهۡرَكَ","tr":"Allathee anqada thahraka","de":"die deinen Rücken niederdrückte"},{"id":4,"ar":"وَرَفَعۡنَا لَكَ ذِكۡرَكَ","tr":"WarafaAAna laka thikraka","de":"und dir dein Ansehen erhöht"},{"id":5,"ar":"فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا","tr":"Fainna maAAa alAAusri yusran","de":"Also gewiß, mit der Erschwernis ist Erleichterung"},{"id":6,"ar":"إِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرٗا","tr":"Inna maAAa alAAusri yusran","de":"gewiß, mit der Erschwernis ist Erleichterung"},{"id":7,"ar":"فَإِذَا فَرَغۡتَ فَٱنصَبۡ","tr":"Faitha faraghta fainsab","de":"Wenn du nun fertig bist, dann strenge dich an"},{"id":8,"ar":"وَإِلَىٰ رَبِّكَ فَٱرۡغَب","tr":"Waila rabbika fairghab","de":"und nach deinem Herrn richte dein Begehren aus"}]}