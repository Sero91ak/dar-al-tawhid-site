{"id":86,"name":"الطارق","transliteration":"At-Tariq","type":"meccan","total_verses":17,"verses":[{"id":1,"ar":"وَٱلسَّمَآءِ وَٱلطَّارِقِ","tr":"Waalssamai waalttariqi","tr_readable":"Wassamaaa'i wattaariq","tr_academic":"wal-samāi wal-ṭāriqi","de":"Beim Himmel und dem Pochenden"},{"id":2,"ar":"وَمَآ أَدۡرَىٰكَ مَا ٱلطَّارِقُ","tr":"Wama adraka ma alttariqu","tr_readable":"Wa maaa adraaka mattaariq","tr_academic":"wamā adrāka mā l-ṭāriqu","de":"Und was läßt dich wissen, was der Pochende ist"},{"id":3,"ar":"ٱلنَّجۡمُ ٱلثَّاقِبُ","tr":"Alnnajmu alththaqibu","tr_readable":"Annajmus saaqib","tr_academic":"al-najmu l-thāqibu","de":"(Es ist) der durchbohrend helle Stem"},{"id":4,"ar":"إِن كُلُّ نَفۡسٖ لَّمَّا عَلَيۡهَا حَافِظٞ","tr":"In kullu nafsin lamma AAalayha hafithun","tr_readable":"In kullu nafsil lammaa 'alaihaa haafiz","tr_academic":"in kullu nafsin lammā ʿalayhā ḥāfiẓun","de":"Es gibt keine Seele, über der nicht ein Hüter (eingesetzt) ist"},{"id":5,"ar":"فَلۡيَنظُرِ ٱلۡإِنسَٰنُ مِمَّ خُلِقَ","tr":"Falyanthuri alinsanu mimma khuliqa","tr_readable":"Fal yanzuril insaanu mimma khuliq","tr_academic":"falyanẓuri l-insānu mimma khuliqa","de":"So soll der Mensch doch hinsehen, woraus er erschaffen ist"},{"id":6,"ar":"خُلِقَ مِن مَّآءٖ دَافِقٖ","tr":"Khuliqa min main dafiqin","tr_readable":"Khuliqa mim maaa'in daafiq","tr_academic":"khuliqa min māin dāfiqin","de":"Er ist aus sich ergießendem Wasser erschaffen"},{"id":7,"ar":"يَخۡرُجُ مِنۢ بَيۡنِ ٱلصُّلۡبِ وَٱلتَّرَآئِبِ","tr":"Yakhruju min bayni alssulbi waalttaraibi","tr_readable":"Yakhruju mim bainissulbi wat taraaa'ib","tr_academic":"yakhruju min bayni l-ṣul'bi wal-tarāibi","de":"das zwischen der Lende und der (weiblichen) Brust hervorkommt"},{"id":8,"ar":"إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ","tr":"Innahu AAala rajAAihi laqadirun","tr_readable":"Innahoo 'alaa raj'ihee laqaadir","tr_academic":"innahu ʿalā rajʿihi laqādirun","de":"Er hat die Macht dazu, ihn zurückkehren zu lassen"},{"id":9,"ar":"يَوۡمَ تُبۡلَى ٱلسّ