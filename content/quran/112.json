{"id":112,"name":"الإخلاص","transliteration":"Al-Ikhlas","type":"meccan","total_verses":4,"verses":[{"id":1,"ar":"قُلۡ هُوَ ٱللَّهُ أَحَدٌ","tr":"Qul huwa Allahu ahadun","de":"Sag: Er ist Allah, Einer"},{"id":2,"ar":"ٱللَّهُ ٱلصَّمَدُ","tr":"Allahu alssamadu","de":"Allah, der Überlegene"},{"id":3,"ar":"لَمۡ يَلِدۡ وَلَمۡ يُولَدۡ","tr":"Lam yalid walam yooladu","de":"Er hat nicht gezeugt und ist nicht gezeugt worden"},{"id":4,"ar":"وَلَمۡ يَكُن لَّهُۥ كُفُوًا أَحَدُۢ","tr":"Walam yakun lahu kufuwan ahadun","de":"und niemand ist Ihm jemals gleich"}]}