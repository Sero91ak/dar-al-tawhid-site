{"id":81,"name":"التكوير","transliteration":"At-Takwir","type":"meccan","total_verses":29,"verses":[{"id":1,"ar":"إِذَا ٱلشَّمۡسُ كُوِّرَتۡ","tr":"Itha alshshamsu kuwwirat","tr_readable":"Izash shamsu kuwwirat","tr_academic":"idhā l-shamsu kuwwirat","de":"Wenn die Sonne umschlungen wird’"},{"id":2,"ar":"وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ","tr":"Waitha alnnujoomu inkadarat","tr_readable":"Wa izan nujoomun kadarat","tr_academic":"wa-idhā l-nujūmu inkadarat","de":"und wenn die Sterne verstreut werden"},{"id":3,"ar":"وَإِذَا ٱلۡجِبَالُ سُيِّرَتۡ","tr":"Waitha aljibalu suyyirat","tr_readable":"Wa izal jibaalu suyyirat","tr_academic":"wa-idhā l-jibālu suyyirat","de":"und wenn die Berge versetzt werden"},{"id":4,"ar":"وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ","tr":"Waitha alAAisharu AAuttilat","tr_readable":"Wa izal 'ishaaru 'uttilat","tr_academic":"wa-idhā l-ʿishāru ʿuṭṭilat","de":"und wenn die trächtigen Kamelstuten vernachlässigt werden"},{"id":5,"ar":"وَإِذَا ٱلۡوُحُوشُ حُشِرَتۡ","tr":"Waitha alwuhooshu hushirat","tr_readable":"Wa izal wuhooshu hushirat","tr_academic":"wa-idhā l-wuḥūshu ḥushirat","de":"und wenn die wilden Tiere versammelt werden"},{"id":6,"ar":"وَإِذَا ٱلۡبِحَارُ سُجِّرَتۡ","tr":"Waitha albiharu sujjirat","tr_readable":"Wa izal bihaaru sujjirat","tr_academic":"wa-idhā l-biḥāru sujjirat","de":"und wenn die Meere zum Überfließen gebracht werden"},{"id":7,"ar":"وَإِذَا ٱلنُّفُوسُ زُوِّجَتۡ","tr":"Waitha alnnufoosu zuwwijat","tr_readable":"Wa izan nufoosu zuwwijat","tr_academic":"wa-idhā l-nufūsu zuwwijat","de":"und wenn die Seelen gepaart werden"},{"id":8,"ar":"وَإِذَا ٱلۡمَوۡءُۥدَةُ سُئِلَتۡ","tr":"Waitha almawoodatu suilat","tr_readable":"Wa izal maw'oodatu su'ilat","tr_academic":"wa-idhā l-mawūdatu su-ilat","de":"und wenn das lebendig begrabene Mädchen gefragt wird"},{"id":9,"ar":"بِأَيِّ ذَنۢبٖ قُتِلَتۡ","tr":"Biayyi thanbin qutilat","tr_readable":"Bi ayyi zambin qutilat","tr_academic":"bi-ayyi dhanbin qutilat","de":"wegen welcher Sünde es getötet wurde"},{"id":10,"ar":"وَإِذَا ٱلصُّحُفُ نُشِرَتۡ","tr":"Waitha alssuhufu nushirat","tr_readable":"Wa izas suhufu nushirat","tr_academic":"wa-idhā l-ṣuḥufu nushirat","de":"und wenn die Blätter aufgeschlagen werden"},{"id":11,"ar":"وَإِذَا ٱلسَّمَآءُ كُشِطَتۡ","tr":"Waitha alssamao kushitat","tr_readable":"Wa izas samaaa'u kushitat","tr_academic":"wa-idhā l-samāu kushiṭat","de":"und wenn der Himmel abgezogen wird"},{"id":12,"ar":"وَإِذَا ٱلۡجَحِيمُ سُعِّرَتۡ","tr":"Waitha aljaheemu suAAAAirat","tr_readable":"Wa izal jaheemu su'-'irat","tr_academic":"wa-idhā l-jaḥīmu suʿʿirat","de":"und wenn die Hölle angefacht wird"},{"id":13,"ar":"وَإِذَا ٱلۡجَنَّةُ أُزۡلِفَتۡ","tr":"Waitha aljannatu ozlifat","tr_readable":"Wa izal jannatu uzlifat","tr_academic":"wa-idhā l-janatu uz'lifat","de":"und wenn der (Paradies)garten nahe herangebracht wird"},{"id":14,"ar":"عَلِمَتۡ نَفۡسٞ مَّآ أَحۡضَرَتۡ","tr":"AAalimat nafsun ma ahdarat","tr_readable":"'Alimat nafsum maaa ahdarat","tr_academic":"ʿalimat nafsun mā aḥḍarat","de":"wird eine (jede) Seele erfahren, was sie vorgebracht hat"},{"id":15,"ar":"فَلَآ أُقۡسِمُ بِٱلۡخُنَّسِ","tr":"Fala oqsimu bialkhunnasi","tr_readable":"Falaaa uqsimu bil khunnas","tr_academic":"falā uq'simu bil-khunasi","de":"Nein! Ich schwöre bei den sich Verbergenden"},{"id":16,"ar":"ٱلۡجَوَارِ ٱلۡكُنَّسِ","tr":"Aljawari alkunnasi","tr_readable":"Al jawaaril kunnas","tr_academic":"al-jawāri l-kunasi","de":"den Dahinziehenden und sich wieder Zeigenden"},{"id":17,"ar":"وَٱلَّيۡلِ إِذَا عَسۡعَسَ","tr":"Waallayli itha AAasAAasa","tr_readable":"Wallaili izaa 'as'as","tr_academic":"wa-al-layli idhā ʿasʿasa","de":"und bei der Nacht, wenn sie anbricht"},{"id":18,"ar":"وَٱلصُّبۡحِ إِذَا تَنَفَّسَ","tr":"Waalssubhi itha tanaffasa","tr_readable":"Wassubhi izaa tanaffas","tr_academic":"wal-ṣub'ḥi idhā tanaffasa","de":"und bei dem Morgen, wenn er Atem schöpft"},{"id":19,"ar":"إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ","tr":"Innahu laqawlu rasoolin kareemin","tr_readable":"Innahoo laqawlu rasoolin kareem","tr_academic":"innahu laqawlu rasūlin karīmin","de":"Dies sind wahrlich die Worte eines edlen Gesandten"},{"id":20,"ar":"ذِي قُوَّةٍ عِندَ ذِي ٱلۡعَرۡشِ مَكِينٖ","tr":"Thee quwwatin AAinda thee alAAarshi makeenin","tr_readable":"Zee quwwatin 'inda zil 'arshi makeen","tr_academic":"dhī quwwatin ʿinda dhī l-ʿarshi makīnin","de":"Besitzer von Kraft und beim Herrn des Thrones in Ansehen"},{"id":21,"ar":"مُّطَاعٖ ثَمَّ أَمِينٖ","tr":"MutaAAin thamma ameenin","tr_readable":"Mutaa'in samma ameen","tr_academic":"muṭāʿin thamma amīnin","de":"dem man dort gehorcht und (der) vertrauenswürdig (ist)"},{"id":22,"ar":"وَمَا صَاحِبُكُم بِمَجۡنُونٖ","tr":"Wama sahibukum bimajnoonin","tr_readable":"Wa maa saahibukum bimajnoon","tr_academic":"wamā ṣāḥibukum bimajnūnin","de":"Und euer Gefährte ist kein Besessener"},{"id":23,"ar":"وَلَقَدۡ رَءَاهُ بِٱلۡأُفُقِ ٱلۡمُبِينِ","tr":"Walaqad raahu bialofuqi almubeeni","tr_readable":"Wa laqad ra aahu bilufuqil mubeen","tr_academic":"walaqad raāhu bil-ufuqi l-mubīni","de":"Er hat ihn ja am deutlichen Gesichtskreis gesehen"},{"id":24,"ar":"وَمَا هُوَ عَلَى ٱلۡغَيۡبِ بِضَنِينٖ","tr":"Wama huwa AAala alghaybi bidaneenin","tr_readable":"Wa maa huwa 'alal ghaibi bidaneen","tr_academic":"wamā huwa ʿalā l-ghaybi biḍanīnin","de":"und er hält nicht aus Geiz das Verborgene zurück"},{"id":25,"ar":"وَمَا هُوَ بِقَوۡلِ شَيۡطَٰنٖ رَّجِيمٖ","tr":"Wama huwa biqawli shaytanin rajeemin","tr_readable":"Wa maa huwa biqawli shaitaanir rajeem","tr_academic":"wamā huwa biqawli shayṭānin rajīmin","de":"Und es sind nicht die Worte eines gesteinigten Satans"},{"id":26,"ar":"فَأَيۡنَ تَذۡهَبُونَ","tr":"Faayna tathhaboona","tr_readable":"Fa ayna tazhaboon","tr_academic":"fa-ayna tadhhabūna","de":"Wo geht ihr denn hin"},{"id":27,"ar":"إِنۡ هُوَ إِلَّا ذِكۡرٞ لِّلۡعَٰلَمِينَ","tr":"In huwa illa thikrun lilAAalameena","tr_readable":"In huwa illaa zikrul lil'aalameen","tr_academic":"in huwa illā dhik'run lil'ʿālamīna","de":"Es ist nur eine Ermahnung für die Weltenbewohner"},{"id":28,"ar":"لِمَن شَآءَ مِنكُمۡ أَن يَسۡتَقِيمَ","tr":"Liman shaa minkum an yastaqeema","tr_readable":"Liman shaaa'a minkum ai yastaqeem","tr_academic":"liman shāa minkum an yastaqīma","de":"für jemanden von euch, der sich recht verhalten will"},{"id":29,"ar":"وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلۡعَٰلَمِينَ","tr":"Wama tashaoona illa an yashaa Allahu rabbu alAAalameena","tr_readable":"Wa maa tashaaa'oona illaaa ai yashaaa 'al laahu Rabbul 'Aalameen","tr_academic":"wamā tashāūna illā an yashāa l-lahu rabbu l-ʿālamīna","de":"Und ihr könnt nicht wollen, außer daß Allah will, (Er), der Herr der Weltenbewohner"}]}